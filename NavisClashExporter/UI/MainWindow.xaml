<Window x:Class="NavisClashExporter.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                Background="#FFF5F6FA"
        FontFamily="Segoe UI"
        FontSize="13"
        Title="ClashRunner"
        Width="850" Height="600"
        MinWidth="700" MinHeight="450"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/NavisClashExporter;component/UI/Styles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Grid Margin="14,10,14,14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Верхняя панель -->
        <DockPanel Grid.Row="0" Margin="0,0,0,10">
            <TextBlock Text="МОСПРОЕКТ" Style="{StaticResource Header}" VerticalAlignment="Center"/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <CheckBox x:Name="chkImages"
                          Content="Экспортировать изображения"
                          IsChecked="True"
                          VerticalAlignment="Center"
                          Margin="0,0,16,0"/>
                <Button Content="⚙ Настройки БД"
                        Style="{StaticResource SecondaryButton}"
                        Padding="12,6" FontSize="12"
                        Margin="0,0,8,0"
                        Click="OnSettings_Click"/>
                <Button Content="Обновить"
                        Style="{StaticResource SecondaryButton}"
                        Padding="12,6" FontSize="12"
                        Click="OnRefresh_Click"/>
            </StackPanel>
        </DockPanel>

        <!-- Основной контент -->
        <TabControl Grid.Row="1">

            <!-- ── Вкладка Проекты ── -->
            <TabItem Header="Проекты">
                <Grid Margin="0,12,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Таблица проектов -->
                    <Border Grid.Row="0"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="1" CornerRadius="8"
                            ClipToBounds="True">
                        <DataGrid x:Name="ProjectsGrid"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True"
                                  SelectionMode="Single"
                                  CanUserSortColumns="True"
                                  HeadersVisibility="Column"
                                  BorderThickness="0"
                                  SelectionChanged="ProjectsGrid_SelectionChanged">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="НАЗВАНИЕ"
                                                    Binding="{Binding Name}"
                                                    Width="*"/>
                                <DataGridTextColumn Header="NWF ФАЙЛ"
                                                    Binding="{Binding NwfPath}"
                                                    Width="2*"/>
                                <DataGridTextColumn Header="ДИРЕКТОРИЯ"
                                                    Binding="{Binding Directory.Code}"
                                                    Width="120"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Border>

                    <!-- Кнопки управления проектами -->
                    <DockPanel Grid.Row="1" Margin="0,10,0,0">
                        <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                            <Button Content="Добавить"
                                    Style="{StaticResource PrimaryButton}"
                                    Padding="14,7" FontSize="12"
                                    Margin="0,0,6,0"
                                    Click="OnAdd_Click"/>
                            <Button x:Name="btnEdit"
                                    Content="Изменить"
                                    Style="{StaticResource SecondaryButton}"
                                    Padding="14,7" FontSize="12"
                                    Margin="0,0,6,0"
                                    IsEnabled="False"
                                    Click="OnEdit_Click"/>
                            <Button x:Name="btnDelete"
                                    Content="Удалить"
                                    Style="{StaticResource DangerButton}"
                                    Padding="14,7" FontSize="12"
                                    IsEnabled="False"
                                    Click="OnDelete_Click"/>
                        </StackPanel>

                        <Button x:Name="btnRun"
                                Content="Запустить экспорт"
                                Style="{StaticResource PrimaryButton}"
                                Padding="20,7" FontSize="13"
                                HorizontalAlignment="Right"
                                IsEnabled="False"
                                Click="OnRunNow_Click"/>
                    </DockPanel>
                </Grid>
            </TabItem>

            <!-- ── Вкладка Автослушатель ── -->
            <TabItem Header="Автослушатель">
                <Grid Margin="0,12,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Панель управления поллером -->
                    <Border Grid.Row="0"
                            Background="{StaticResource BgCardBrush}"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="1" CornerRadius="8"
                            Padding="16,14" Margin="0,0,0,10">
                        <DockPanel>
                            <StackPanel Orientation="Horizontal" DockPanel.Dock="Right">
                                <Button x:Name="btnStart"
                                        Content="▶  Старт"
                                        Style="{StaticResource PrimaryButton}"
                                        Padding="16,7" FontSize="12"
                                        Margin="0,0,8,0"
                                        Click="OnPollerStart_Click"/>
                                <Button x:Name="btnStop"
                                        Content="■  Стоп"
                                        Style="{StaticResource DangerButton}"
                                        Padding="16,7" FontSize="12"
                                        IsEnabled="False"
                                        Click="OnPollerStop_Click"/>
                            </StackPanel>

                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Style="{StaticResource Label}"
                                           Text="СТАТУС СЛУШАТЕЛЯ"/>
                                <TextBlock x:Name="txtStatus"
                                           Text="Слушатель не запущен"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           FontSize="13"/>
                            </StackPanel>
                        </DockPanel>
                    </Border>

                    <!-- Описание -->
                    <Border Grid.Row="1"
                            Background="{StaticResource BgCardBrush}"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="1" CornerRadius="8"
                            Padding="16,14">
                        <StackPanel>
                            <TextBlock Style="{StaticResource Label}" Text="КАК РАБОТАЕТ АВТОСЛУШАТЕЛЬ"/>
                            <TextBlock TextWrapping="Wrap"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       FontSize="12" LineHeight="20">
                                Слушатель опрашивает базу данных каждые 20 секунд на наличие новых задач.
                                Когда задача появляется — автоматически открывает NWF файл проекта,
                                запускает проверки коллизий и выгружает результаты в БД.
                            </TextBlock>
                        </StackPanel>
                    </Border>
                </Grid>
            </TabItem>

            <!-- ── Вкладка Лог ── -->
            <TabItem Header="Лог">
                <Grid Margin="0,12,0,0">
                    <Border BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="1" CornerRadius="8"
                            ClipToBounds="True">
                        <ListBox x:Name="LogBox"
                                 FontFamily="Consolas"
                                 FontSize="11"
                                 BorderThickness="0"
                                 ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                 ScrollViewer.VerticalScrollBarVisibility="Auto"/>
                    </Border>
                </Grid>
            </TabItem>

        </TabControl>
    </Grid>
</Window>
