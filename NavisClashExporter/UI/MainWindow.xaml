<Window x:Class="NavisClashExporter.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="getBIM — ClashRunner" Height="580" Width="750"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResizeWithGrip">
    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="Margin" Value="3"/>
        </Style>
    </Window.Resources>
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Верхняя панель -->
        <DockPanel Grid.Row="0" Margin="0,0,0,10">
            <TextBlock Text="getBIM ClashRunner" FontSize="18" FontWeight="Bold" VerticalAlignment="Center"/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="⚙ Настройки БД" Click="OnSettings_Click"/>
                <Button Content="Обновить" Click="OnRefresh_Click"/>
            </StackPanel>
        </DockPanel>

        <!-- Проекты -->
        <GroupBox Grid.Row="1" Header="Проекты Navisworks" Padding="8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="110"/>
                </Grid.ColumnDefinitions>
                <DataGrid x:Name="ProjectsGrid"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          SelectionMode="Single"
                          CanUserSortColumns="True"
                          HeadersVisibility="Column"
                          SelectionChanged="ProjectsGrid_SelectionChanged">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Название" Binding="{Binding Name}" Width="*"/>
                        <DataGridTextColumn Header="NWF файл" Binding="{Binding NwfPath}" Width="2*"/>
                        <DataGridTextColumn Header="Директория" Binding="{Binding Directory.Code}" Width="100"/>
                    </DataGrid.Columns>
                </DataGrid>
                <StackPanel Grid.Column="1" Margin="8,0,0,0">
                    <Button Content="Добавить" Click="OnAdd_Click"/>
                    <Button Content="Изменить" Click="OnEdit_Click" x:Name="btnEdit" IsEnabled="False"/>
                    <Button Content="Удалить" Click="OnDelete_Click" x:Name="btnDelete" IsEnabled="False"/>
                    <Separator Margin="0,10"/>
                    <Button Content="▶ Запустить" Click="OnRunNow_Click" x:Name="btnRun"
                            IsEnabled="False" Background="#4CAF50" Foreground="White" FontWeight="Bold"/>
                </StackPanel>
            </Grid>
        </GroupBox>

        <!-- Статус слушателя -->
        <GroupBox Grid.Row="2" Header="Автослушатель" Padding="8" Margin="0,8,0,0">
            <DockPanel>
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Right">
                    <Button Content="▶ Старт" Click="OnPollerStart_Click" x:Name="btnStart"/>
                    <Button Content="■ Стоп"  Click="OnPollerStop_Click"  x:Name="btnStop" IsEnabled="False"/>
                </StackPanel>
                <CheckBox x:Name="chkImages" Content="Экспортировать изображения"
                          IsChecked="True" VerticalAlignment="Center" Margin="0,0,20,0"/>
                <TextBlock x:Name="txtStatus" Text="Слушатель не запущен"
                           VerticalAlignment="Center" Foreground="Gray"/>
            </DockPanel>
        </GroupBox>

        <!-- Лог -->
        <GroupBox Grid.Row="3" Header="Лог" Padding="4" Margin="0,8,0,0" MaxHeight="130">
            <ListBox x:Name="LogBox" FontFamily="Consolas" FontSize="11"
                     ScrollViewer.HorizontalScrollBarVisibility="Auto"/>
        </GroupBox>
    </Grid>
</Window>