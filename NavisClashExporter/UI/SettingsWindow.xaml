<Window x:Class="NavisClashExporter.UI.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Подключение к БД" Width="380" Height="420"
        ResizeMode="NoResize" WindowStartupLocation="CenterOwner">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Настройки PostgreSQL"
                   FontSize="16" FontWeight="Bold" Margin="0,0,0,16"/>

        <StackPanel Grid.Row="1">
            <TextBlock Text="Хост" FontWeight="SemiBold" Margin="0,0,0,3"/>
            <TextBox x:Name="txtHost" Margin="0,0,0,10" Padding="6,5"/>

            <TextBlock Text="Порт" FontWeight="SemiBold" Margin="0,0,0,3"/>
            <TextBox x:Name="txtPort" Margin="0,0,0,10" Padding="6,5" Width="100" HorizontalAlignment="Left"/>

            <TextBlock Text="База данных" FontWeight="SemiBold" Margin="0,0,0,3"/>
            <TextBox x:Name="txtDatabase" Margin="0,0,0,10" Padding="6,5"/>

            <TextBlock Text="Пользователь" FontWeight="SemiBold" Margin="0,0,0,3"/>
            <TextBox x:Name="txtUsername" Margin="0,0,0,10" Padding="6,5"/>

            <TextBlock Text="Пароль" FontWeight="SemiBold" Margin="0,0,0,3"/>
            <PasswordBox x:Name="txtPassword" Margin="0,0,0,10" Padding="6,5"/>
        </StackPanel>

        <Border Grid.Row="2" Background="#F5F5F5" BorderBrush="#DDD" BorderThickness="1"
                CornerRadius="4" Padding="10,8" Margin="0,4,0,12">
            <TextBlock x:Name="txtTestResult" Text="Нажмите «Проверить»" TextWrapping="Wrap" FontSize="12"/>
        </Border>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Проверить" Padding="12,6" Margin="0,0,8,0" Click="OnTest_Click"/>
            <Button Content="Сохранить" Padding="12,6" Margin="0,0,8,0"
                    Background="#4A8FE7" Foreground="White" FontWeight="Bold" Click="OnSave_Click"/>
            <Button Content="Отмена" Padding="12,6" Click="OnCancel_Click"/>
        </StackPanel>
    </Grid>
</Window>