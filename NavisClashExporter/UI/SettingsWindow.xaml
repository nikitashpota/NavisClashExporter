<Window x:Class="NavisClashExporter.UI.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Подключение к БД" Width="380" Height="620"
        ResizeMode="NoResize" WindowStartupLocation="CenterOwner"
        Background="#FFF5F6FA" FontFamily="Segoe UI" FontSize="13">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/NavisClashExporter;component/UI/Styles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Grid Margin="24,20,24,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <TextBlock Grid.Row="0"
                   Text="Настройки PostgreSQL"
                   Style="{StaticResource Header}"
                   Margin="0,0,0,20"/>

        <!-- Поля -->
        <StackPanel Grid.Row="1">
            <TextBlock Style="{StaticResource Label}" Text="ХОСТ"/>
            <TextBox x:Name="txtHost" Margin="0,0,0,12"/>

            <TextBlock Style="{StaticResource Label}" Text="ПОРТ"/>
            <TextBox x:Name="txtPort" Margin="0,0,0,12"
                     Width="100" HorizontalAlignment="Left"/>

            <TextBlock Style="{StaticResource Label}" Text="БАЗА ДАННЫХ"/>
            <TextBox x:Name="txtDatabase" Margin="0,0,0,12"/>

            <TextBlock Style="{StaticResource Label}" Text="ПОЛЬЗОВАТЕЛЬ"/>
            <TextBox x:Name="txtUsername" Margin="0,0,0,12"/>

            <TextBlock Style="{StaticResource Label}" Text="ПАРОЛЬ"/>
            <PasswordBox x:Name="txtPassword" Margin="0,0,0,0"/>
        </StackPanel>

        <!-- Результат проверки -->
        <Border Grid.Row="2"
                Background="{StaticResource BgCardBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="1" CornerRadius="6"
                Padding="12,10" Margin="0,14,0,14">
            <TextBlock x:Name="txtTestResult"
                       Text="Нажмите «Проверить»"
                       TextWrapping="Wrap"
                       FontSize="12"
                       Foreground="{StaticResource TextSecondaryBrush}"/>
        </Border>

        <!-- Кнопки -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Проверить"
                    Style="{StaticResource SecondaryButton}"
                    Padding="14,8" Margin="0,0,8,0"
                    Click="OnTest_Click"/>
            <Button Content="Сохранить"
                    Style="{StaticResource PrimaryButton}"
                    Padding="14,8" Margin="0,0,8,0"
                    Click="OnSave_Click"/>
            <Button Content="Отмена"
                    Style="{StaticResource SecondaryButton}"
                    Padding="14,8"
                    Click="OnCancel_Click"/>
        </StackPanel>
    </Grid>
</Window>
