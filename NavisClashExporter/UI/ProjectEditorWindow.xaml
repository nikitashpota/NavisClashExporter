<Window x:Class="NavisClashExporter.UI.ProjectEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Проект Navisworks" Width="540" Height="400"
        ResizeMode="NoResize" WindowStartupLocation="CenterOwner"
        Background="#FFF5F6FA" FontFamily="Segoe UI" FontSize="13">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/NavisClashExporter;component/UI/Styles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Grid Margin="24,20,24,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <TextBlock Grid.Row="0" x:Name="txtTitle"
                   Text="Создание проекта"
                   Style="{StaticResource Header}"
                   Margin="0,0,0,20"/>

        <!-- Поля ввода -->
        <StackPanel Grid.Row="1">
            <TextBlock Style="{StaticResource Label}"
                       Text="НАЗВАНИЕ"/>
            <TextBlock Text="Должно совпадать с project_name в RevitSync"
                       Foreground="{StaticResource TextMutedBrush}"
                       FontSize="11" Margin="0,0,0,5"/>
            <TextBox x:Name="txtName" Margin="0,0,0,14"/>

            <TextBlock Style="{StaticResource Label}" Text="ПУТЬ К NWF ФАЙЛУ"/>
            <DockPanel Margin="0,0,0,14">
                <Button DockPanel.Dock="Right"
                        Content="Обзор"
                        Style="{StaticResource SecondaryButton}"
                        Padding="12,8" Margin="8,0,0,0"
                        Click="OnBrowse_Click"/>
                <TextBox x:Name="txtNwfPath"/>
            </DockPanel>

            <TextBlock Style="{StaticResource Label}" Text="ДИРЕКТОРИЯ РЕЗУЛЬТАТОВ"/>
            <ComboBox x:Name="cmbDirectory" DisplayMemberPath="Code"/>
        </StackPanel>

        <!-- Кнопки -->
        <StackPanel Grid.Row="2" Orientation="Horizontal"
                    HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button Content="Отмена"
                    Style="{StaticResource SecondaryButton}"
                    Padding="16,8" Margin="0,0,8,0"
                    Click="OnCancel_Click"/>
            <Button Content="Сохранить"
                    Style="{StaticResource PrimaryButton}"
                    Padding="16,8"
                    Click="OnSave_Click"/>
        </StackPanel>
    </Grid>
</Window>
