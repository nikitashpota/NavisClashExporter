<Window x:Class="NavisClashExporter.UI.ProjectEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Проект Navisworks" Width="520" Height="340"
        ResizeMode="NoResize" WindowStartupLocation="CenterOwner">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" x:Name="txtTitle" Text="Создание проекта"
                   FontSize="16" FontWeight="Bold" Margin="0,0,0,16"/>

        <StackPanel Grid.Row="1">
            <TextBlock Text="Название (должно совпадать с project_name в RevitSync)"
                       FontWeight="SemiBold" Margin="0,0,0,3"/>
            <TextBox x:Name="txtName" Margin="0,0,0,12" Padding="6,5"/>

            <TextBlock Text="Путь к NWF файлу" FontWeight="SemiBold" Margin="0,0,0,3"/>
            <DockPanel Margin="0,0,0,12">
                <Button DockPanel.Dock="Right" Content="Обзор" Padding="10,5"
                        Margin="8,0,0,0" Click="OnBrowse_Click"/>
                <TextBox x:Name="txtNwfPath" Padding="6,5"/>
            </DockPanel>

            <TextBlock Text="Директория результатов" FontWeight="SemiBold" Margin="0,0,0,3"/>
            <ComboBox x:Name="cmbDirectory" Margin="0,0,0,12" Padding="6,5"
                      DisplayMemberPath="Code"/>
        </StackPanel>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Сохранить" Padding="14,6" Margin="0,0,8,0"
                    Background="#4A8FE7" Foreground="White" FontWeight="Bold" Click="OnSave_Click"/>
            <Button Content="Отмена" Padding="14,6" Click="OnCancel_Click"/>
        </StackPanel>
    </Grid>
</Window>